rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(userId) { return signedIn() && request.auth.uid == userId; }
    function isAdmin() { return signedIn() && request.auth.token.email == 'admin@hostelradar.com'; }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /posts/{postId} {
      allow read, create: if signedIn();
      allow update, delete: if signedIn() && resource.data.posterUid == request.auth.uid;
    }

    match /messTracker/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /canteenTab/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /personalGoals/{userId}/goals/{goalId} {
      allow read, write: if isOwner(userId);
    }

    match /ratings/{ratingId} {
      allow read, create: if signedIn();
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /complaints/{complaintId} {
      allow read, create: if signedIn();
    }

    match /anonIds/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isOwner(userId);
    }

    match /presence/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /whispers/{messageId} {
      allow read, create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /alerts/{alertId} {
      allow read, create: if signedIn();
      allow update, delete: if signedIn() && resource.data.posterUid == request.auth.uid;
    }
  }
}
