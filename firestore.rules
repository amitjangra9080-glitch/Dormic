rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    // Posts - anyone logged in can read, only owner can update/delete
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.posterUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.posterUid == request.auth.uid;
    }
    // Mess tracker - private per user
    match /messTracker/{userId}/{date}/{meal} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Ratings - anyone logged in can write
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    // Complaints - anyone logged in can write
    match /complaints/{complaintId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}
